WHATSAPP_ACCESS_TOKEN=your_meta_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_meta_phone_number_id
WHATSAPP_TO_NUMBER=917902871746
WHATSAPP_API_VERSION=v23.0
PORT=3001

# EmailJS client-side config for Contact and Eligibility forms.
# Replace each value with your own EmailJS dashboard values.
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_CONTACT_TEMPLATE_ID=your_contact_template_id
VITE_EMAILJS_ELIGIBILITY_TEMPLATE_ID=your_eligibility_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Optional: eligibility can use separate EmailJS credentials.
# VITE_EMAILJS_ELIGIBILITY_SERVICE_ID=your_eligibility_service_id
# VITE_EMAILJS_ELIGIBILITY_PUBLIC_KEY=your_eligibility_public_key
